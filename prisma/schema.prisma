generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageType {
  DEAL
  ARTICLE
  DESTINATION
  ITINERARY
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  name      String   @unique
  slug      String
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String?  @db.ObjectId
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Tag {
  id    String    @id @default(auto()) @map("_id") @db.ObjectId
  name  String    @unique
  slug  String
  posts PostTag[] @relation("TagToPostTags")
}

model Post {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  authorId    String     @db.ObjectId
  author      User       @relation(fields: [authorId], references: [id])
  categoryId  String     @db.ObjectId
  category    Category   @relation(fields: [categoryId], references: [id])
  content     String
  createdAt   DateTime   @default(now())
  image       String?
  slug        String     @unique
  description String?
  status      PostStatus @default(DRAFT)
  title       String
  type        PageType   @default(ARTICLE)
  tags        PostTag[]  @relation("PostToPostTags")
  updatedAt   DateTime   @updatedAt
  comments    Comment[]
}

model TravelDeal {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  image       String
  description String?
  location    String?
  duration    String?
  fullPrice   String?
  price       String
  category    String?
  label       String?
  tag         String?
  buttonText  String
  buttonUrl   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PostTag {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  post   Post   @relation("PostToPostTags", fields: [postId], references: [id])
  postId String @db.ObjectId
  tag    Tag    @relation("TagToPostTags", fields: [tagId], references: [id])
  tagId  String @db.ObjectId

  @@unique([postId, tagId], name: "postId_tagId")
}

model User {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  bio                String
  createdAt          DateTime             @default(now())
  email              String               @unique
  lastName           String?
  name               String?
  password           String
  profilePicture     String
  role               Role                 @default(USER)
  updatedAt          DateTime             @updatedAt
  username           String               @unique
  comments           Comment[]
  posts              Post[]
  PasswordResetToken PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
