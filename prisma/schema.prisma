generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum PageType {
  PILLAR_ARTICLE    // Your 8000-word comprehensive guides
  CLUSTER_ARTICLE   // Supporting articles (2000-3000 words)
  BLOG_POST         // Personal stories, shorter posts
  LISTICLE          // "Top 10..." posts
  REVIEW            // Destination/hotel reviews
  DEAL              // Travel deals (keep this)
  DESTINATION       // Destination overview pages
  ITINERARY         // Trip itineraries
  GUIDE             // How-to guides
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  name      String   @unique
  slug      String
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String?  @db.ObjectId
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Tag {
  id    String    @id @default(auto()) @map("_id") @db.ObjectId
  name  String    @unique
  slug  String
  posts PostTag[] @relation("TagToPostTags")
}

model Post {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Core Content
  title       String
  slug        String   @unique
  content     String   // Main content (Markdown/HTML)
  excerpt     String?  // Short summary (auto-generate or manual)
  
  // Type & Status
  type        PageType @default(BLOG_POST)
  status      PostStatus @default(DRAFT)
  
  // SEO Fields
  metaTitle       String?  // Custom SEO title (defaults to title if null)
  metaDescription String?  // Custom meta description
  description     String?  // Keep for backward compatibility
  focusKeyword    String?  // Primary SEO keyword
  
  // Media
  image       String?    // Keep for backward compatibility (use heroImage going forward)
  heroImage   String?    // Main hero image (Cloudinary URL)
  
  // Organization & Relations
  authorId    String     @db.ObjectId
  author      User       @relation(fields: [authorId], references: [id])
  categoryId  String     @db.ObjectId
  category    Category   @relation(fields: [categoryId], references: [id])
  tags        PostTag[]  @relation("PostToPostTags")
  
  // Special Flags
  featured    Boolean    @default(false)  // Show on homepage
  pillarPage  Boolean    @default(false)  // Is this pillar content?
  trending    Boolean    @default(false)  // Trending post
  
  // Analytics & Metadata
  views       Int        @default(0)      // View counter
  readTime    Int?       // Estimated read time in minutes
  wordCount   Int?       // Total word count
  
  // Dates
  publishedAt DateTime?  // When it was published
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Relations
  comments      Comment[]
  faqs          FAQ[]          @relation("PostToFAQs")
  itemListItems ItemListItem[] @relation("PostToItemListItems")
  
  // Indexes for performance
  @@index([type, status])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([featured])
}

model FAQ {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  question String
  answer   String
  order    Int    @default(0)
  postId   String @db.ObjectId
  post     Post   @relation("PostToFAQs", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model ItemListItem {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  url    String
  order  Int    @default(0)
  postId String @db.ObjectId
  post   Post   @relation("PostToItemListItems", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model TravelDeal {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  image       String
  description String?
  location    String?
  duration    String?
  fullPrice   String?
  price       String
  category    String?
  label       String?
  tag         String?
  buttonText  String
  buttonUrl   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PostTag {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  post   Post   @relation("PostToPostTags", fields: [postId], references: [id])
  postId String @db.ObjectId
  tag    Tag    @relation("TagToPostTags", fields: [tagId], references: [id])
  tagId  String @db.ObjectId

  @@unique([postId, tagId], name: "postId_tagId")
}

model User {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  bio                String
  createdAt          DateTime             @default(now())
  email              String               @unique
  lastName           String?
  name               String?
  password           String
  profilePicture     String
  role               Role                 @default(USER)
  updatedAt          DateTime             @updatedAt
  username           String               @unique
  comments           Comment[]
  posts              Post[]
  PasswordResetToken PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
